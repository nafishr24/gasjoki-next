generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Testimonial {
  id        Int      @id @default(autoincrement())
  text      String
  name      String
  role      String
  initial   String
  bgClass   String?  @default("#3b82f6")
  rating    Int      @default(5)
  createdAt DateTime @default(now())
}
